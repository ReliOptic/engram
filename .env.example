# Engram Environment Configuration
# Copy this to .env and fill in your keys

# LLM Providers
OPENROUTER_API_KEY=your-openrouter-key-here
OPENAI_API_KEY=your-openai-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Paths (defaults work for local dev)
ENGRAM_CONFIG_DIR=data/config
ENGRAM_DATA_DIR=data

# Sync (optional — leave empty for standalone mode)
# SYNC_SERVER_URL=http://192.168.1.100:9000
# SYNC_DEVICE_NAME=My-PC
