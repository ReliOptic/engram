# OpenRouter API key (for embedding)
OPENROUTER_API_KEY=sk-or-...

# ZEMAS config directory (contains models.json)
# Default: ../../data/config (relative to DB_Builder)
ZEMAS_CONFIG_DIR=/path/to/ZZZ/data/config

# ZEMAS data directory (contains chroma_db/)
# Default: ../../data (relative to DB_Builder)
ZEMAS_DATA_DIR=/path/to/ZZZ/data
