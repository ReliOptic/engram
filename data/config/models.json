{
  "providers": {
    "openrouter": {
      "base_url": "https://openrouter.ai/api/v1",
      "env_key": "OPENROUTER_API_KEY"
    },
    "openai": {
      "base_url": "https://api.openai.com/v1",
      "env_key": "OPENAI_API_KEY"
    }
  },
  "roles": {
    "analyzer": {
      "provider": "openrouter",
      "model": "google/gemini-2.0-flash-lite-001",
      "max_tokens": 4096,
      "temperature": 0.3
    },
    "finder": {
      "provider": "openrouter",
      "model": "google/gemini-3.1-flash-lite-preview",
      "max_tokens": 4096,
      "temperature": 0.2
    },
    "reviewer": {
      "provider": "openrouter",
      "model": "google/gemini-3.1-flash-lite-preview",
      "max_tokens": 4096,
      "temperature": 0.2
    },
    "orchestrator": {
      "provider": "openrouter",
      "model": "google/gemini-3.1-flash-lite-preview",
      "max_tokens": 2048,
      "temperature": 0.1
    },
    "tacit_extraction": {
      "provider": "openrouter",
      "model": "google/gemini-3.1-flash-lite-preview",
      "max_tokens": 4096,
      "temperature": 0.3
    },
    "dreaming": {
      "provider": "openrouter",
      "model": "google/gemini-3.1-flash-lite-preview",
      "max_tokens": 4096,
      "temperature": 0.5
    },
    "embedding": {
      "provider": "openrouter",
      "model": "openai/text-embedding-3-small"
    }
  },
  "cost_per_million_tokens": {
    "google/gemini-3.1-flash-lite-preview": {
      "input": 0.0,
      "output": 0.0
    },
    "openai/gpt-5.4": {
      "input": 2.5,
      "output": 10.0
    },
    "openai/text-embedding-3-small": {
      "input": 0.02,
      "output": 0.0
    }
  }
}