# OpenRouter API key (for embedding)
OPENROUTER_API_KEY=sk-or-...

# ENGRAM config directory (contains models.json)
# Default: ../../data/config (relative to DB_Builder)
ENGRAM_CONFIG_DIR=/path/to/ZZZ/data/config

# ENGRAM data directory (contains chroma_db/)
# Default: ../../data (relative to DB_Builder)
ENGRAM_DATA_DIR=/path/to/ZZZ/data
